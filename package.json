{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "nuke": "find . -name 'node_modules' -type d -exec rm -rf {} \\;",
